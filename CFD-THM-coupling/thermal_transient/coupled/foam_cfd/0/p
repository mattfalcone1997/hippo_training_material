FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 103500;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 103500;
    }
    outlet
    {
        type            calculated;
        value           uniform 103500;
    }
    pipe
    {
        type            calculated;
        value           uniform 103500;
    }
}


